<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0D1222">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NOUVELLE ROUTINE"
        android:textColor="#00E5FF"
        android:textSize="13sp"
        android:letterSpacing="0.20"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="#335566"
        android:textSize="11sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ex: Verifier la meteo chaque matin"
        android:textColor="#CCE8FF"
        android:textSize="13sp"
        android:background="@drawable/card_glass"
        android:padding="12dp"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jour de la semaine"
        android:textColor="#335566"
        android:textSize="11sp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spinnerDay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/card_glass"
        android:paddingStart="12dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Heure approximative"
        android:textColor="#335566"
        android:textSize="11sp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spinnerHour"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/card_glass"
        android:paddingStart="12dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Annuler"
            android:textColor="#335566"
            android:textSize="13sp"
            android:background="@drawable/tab_unselected"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="12dp" android:layout_height="1dp" />

        <TextView
            android:id="@+id/btnCreate"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Creer"
            android:textColor="#050510"
            android:textSize="13sp"
            android:background="@drawable/btn_cyan"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
