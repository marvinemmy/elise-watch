<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen waveform canvas -->
    <com.lnsgroup.elise.companion.EliseWaveView
        android:id="@+id/waveView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="52dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÉLISE"
                android:textColor="#E8FFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.40" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="#1A3A4A"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Connection indicator dot -->
        <View
            android:id="@+id/vConnectionDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_indicator"
            android:layout_marginEnd="14dp" />

        <!-- Stop button -->
        <TextView
            android:id="@+id/btnStop"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="×"
            android:textColor="#3300E5FF"
            android:textSize="22sp"
            android:gravity="center"
            android:background="#00000000"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Bottom status card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:layout_marginBottom="48dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/card_glass"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appuie pour parler"
            android:textColor="#AAE8FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:lineSpacingMultiplier="1.35"
            android:maxLines="4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="· · ·"
            android:textColor="#1A3A4A"
            android:textSize="10sp"
            android:letterSpacing="0.20"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</FrameLayout>
