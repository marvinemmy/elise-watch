<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#010A10">

    <!-- Animation waveform plein écran -->
    <com.lnsgroup.elise.companion.EliseWaveView
        android:id="@+id/waveView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Titre en haut -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="top"
        android:layout_marginTop="56dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ÉLISE"
            android:textColor="#00E5FF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.25" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#1A3A4A"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Statut / réponse en bas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="32dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appuie pour parler"
            android:textColor="#4A8A9A"
            android:textSize="15sp"
            android:gravity="center"
            android:maxLines="3" />

        <!-- Bouton micro — tap zone discrète -->
        <View
            android:id="@+id/btnMic"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/mic_button"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</FrameLayout>
