<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0D1222">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOUVEAU DECLENCHEUR"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:letterSpacing="0.20"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nom"
            android:textColor="#335566"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTriggerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Rapport du matin"
            android:textColor="#CCE8FF"
            android:textSize="13sp"
            android:background="@drawable/card_glass"
            android:padding="12dp"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type de condition"
            android:textColor="#335566"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerConditionType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/card_glass"
            android:paddingStart="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Schedule fields -->
        <LinearLayout
            android:id="@+id/layoutSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jour"
                    android:textColor="#335566"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerTriggerDay"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/card_glass"
                    android:paddingStart="8dp" />
            </LinearLayout>

            <View android:layout_width="10dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Heure"
                    android:textColor="#335566"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerTriggerHour"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/card_glass"
                    android:paddingStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- HR / keyword / inactivity field -->
        <LinearLayout
            android:id="@+id/layoutConditionValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvConditionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Valeur"
                android:textColor="#335566"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etConditionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=""
                android:textColor="#CCE8FF"
                android:textSize="13sp"
                android:background="@drawable/card_glass"
                android:padding="12dp"
                android:inputType="text" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Action Elise"
            android:textColor="#335566"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTriggerAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Lis mes notifications et resume ma journee"
            android:textColor="#CCE8FF"
            android:textSize="13sp"
            android:background="@drawable/card_glass"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnTriggerCancel"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Annuler"
                android:textColor="#335566"
                android:textSize="13sp"
                android:background="@drawable/tab_unselected"
                android:clickable="true"
                android:focusable="true" />

            <View android:layout_width="12dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/btnTriggerCreate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Creer"
                android:textColor="#050510"
                android:textSize="13sp"
                android:background="@drawable/btn_cyan"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
