<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RÉGLAGES"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.30"
            android:paddingTop="56dp"
            android:paddingBottom="24dp" />

        <!-- Section : Versions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VERSIONS"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="App téléphone" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionPhone" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="App montre" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionWatch" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Serveur ÉLISE" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionServer" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section : Montre OTA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISE À JOUR MONTRE"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvOtaStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vérification…"
                android:textColor="#AAE8FF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/btnCheckUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Vérifier maintenant"
                android:textColor="#00E5FF"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/card_glass"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Section : Statut routines -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INTELLIGENCE ADAPTATIVE"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Routines actives" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvRoutineCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#9966FF" android:textSize="13sp" android:text="0" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ÉLISE apprend tes habitudes automatiquement via tes interactions vocales."
                android:textColor="#335566"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Section : Déconnexion -->
        <TextView
            android:id="@+id/btnStopAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Arrêter tous les services ÉLISE"
            android:textColor="#FF2255"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/card_glass"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
