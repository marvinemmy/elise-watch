<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RÉGLAGES"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.30"
            android:paddingTop="56dp"
            android:paddingBottom="24dp" />

        <!-- Section : Versions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VERSIONS"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="App téléphone" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionPhone" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="App montre" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionWatch" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Serveur ÉLISE" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvVersionServer" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#00E5FF" android:textSize="13sp" android:text="—" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section : Montre OTA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISE À JOUR MONTRE"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvOtaStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vérification…"
                android:textColor="#AAE8FF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/btnCheckUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Vérifier maintenant"
                android:textColor="#00E5FF"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/card_glass"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Section : Statut routines -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INTELLIGENCE ADAPTATIVE"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Routines actives" android:textColor="#AAE8FF" android:textSize="13sp" />
                <TextView android:id="@+id/tvRoutineCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#9966FF" android:textSize="13sp" android:text="0" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ÉLISE apprend tes habitudes automatiquement via tes interactions vocales."
                android:textColor="#335566"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Section : Variables personnelles -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VARIABLES PERSONNELLES"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Domicile (trajet)" android:textColor="#335566" android:textSize="11sp" />
                <TextView android:id="@+id/tvHomeAddr" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="2" android:textColor="#AAE8FF" android:textSize="11sp" android:text="—" android:maxLines="2" />
                <TextView android:id="@+id/btnEditHome" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✎" android:textColor="#00E5FF" android:textSize="16sp" android:paddingStart="10dp"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Travail" android:textColor="#335566" android:textSize="11sp" />
                <TextView android:id="@+id/tvWorkAddr" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="2" android:textColor="#AAE8FF" android:textSize="11sp" android:text="—" android:maxLines="2" />
                <TextView android:id="@+id/btnEditWork" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✎" android:textColor="#00E5FF" android:textSize="16sp" android:paddingStart="10dp"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Mode vacances" android:textColor="#335566" android:textSize="11sp" />
                <Switch android:id="@+id/switchVacation" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#00E5FF" android:trackTint="#1A3A4A" />
            </LinearLayout>
        </LinearLayout>

        <!-- Routines programmées -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ROUTINES PROGRAMMEES"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7h30 lun-ven · 8h30 sam-dim — Rapport matin\n21h00 — Check travail demain\nMer/Jeu 20h30 — Rappel plein\nSam/Dim 10h00 — Rappel courses"
                android:textColor="#AAE8FF"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.6"
                android:paddingBottom="12dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/btnReschedule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↺ Reprogrammer"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/tab_selected"
                    android:clickable="true"
                    android:focusable="true" />
                <View android:layout_width="10dp" android:layout_height="1dp" />
                <TextView
                    android:id="@+id/btnTestMorning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▶ Test matin"
                    android:textColor="#335566"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/tab_unselected"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section : WiFi Sync montre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WIFI SYNC MONTRE"
            android:textColor="#335566"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:paddingBottom="8dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Reseau actuel" android:textColor="#335566" android:textSize="11sp" />
                <TextView android:id="@+id/tvWifiSsid" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="2" android:textColor="#AAE8FF" android:textSize="11sp" android:text="—" />
            </LinearLayout>

            <EditText
                android:id="@+id/etWifiPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mot de passe WiFi"
                android:textColor="#AAE8FF"
                android:textColorHint="#335566"
                android:textSize="12sp"
                android:inputType="textPassword"
                android:background="@drawable/card_glass"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/btnWifiSync"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sync montre"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/tab_selected"
                    android:clickable="true"
                    android:focusable="true" />
                <View android:layout_width="10dp" android:layout_height="1dp" />
                <TextView
                    android:id="@+id/btnWifiQr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scanner QR"
                    android:textColor="#335566"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/tab_unselected"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section : Déconnexion -->
        <TextView
            android:id="@+id/btnStopAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Arrêter tous les services ÉLISE"
            android:textColor="#FF2255"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/card_glass"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
