<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tu"
            android:textColor="#00E5FF"
            android:textSize="9sp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvHistoryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1A3A4A"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvHistoryUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAE8FF"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ÉLISE"
        android:textColor="#9966FF"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvHistoryElise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AA88FF"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3" />

</LinearLayout>
