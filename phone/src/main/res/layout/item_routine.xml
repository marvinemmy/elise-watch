<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="8dp">

    <!-- Main row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoutineDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCE8FF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvRoutineMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#335566"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchRoutine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:thumbTint="#00E5FF"
            android:trackTint="#1A3A4A" />

        <TextView
            android:id="@+id/btnMore"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="⋮"
            android:textColor="#335566"
            android:textSize="18sp"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Action row (hidden by default) -->
    <LinearLayout
        android:id="@+id/rowActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnPauseDay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pause\nauj."
            android:textColor="#FFB300"
            android:textSize="10sp"
            android:padding="6dp"
            android:background="@drawable/btn_outline_yellow"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="6dp" android:layout_height="1dp" />

        <TextView
            android:id="@+id/btnPauseWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pause\nsemaine"
            android:textColor="#FFB300"
            android:textSize="10sp"
            android:padding="6dp"
            android:background="@drawable/btn_outline_yellow"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="6dp" android:layout_height="1dp" />

        <TextView
            android:id="@+id/btnPauseMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pause\nmois"
            android:textColor="#FFB300"
            android:textSize="10sp"
            android:padding="6dp"
            android:background="@drawable/btn_outline_yellow"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="6dp" android:layout_height="1dp" />

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Suppri-\nmer"
            android:textColor="#FF4444"
            android:textSize="10sp"
            android:padding="6dp"
            android:background="@drawable/btn_outline_red"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
